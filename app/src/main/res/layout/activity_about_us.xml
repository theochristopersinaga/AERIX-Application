<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="16dp">

    <!-- Back Button -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="80dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_back"
        app:tint="@android:color/white" />

    <!-- Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="About Us"
        android:textColor="@android:color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/txtSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Overview and Development Team"
        android:textColor="#A0FFFFFF"
        android:textSize="14sp"
        android:layout_below="@+id/imgLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp" />
    <!-- AERIX Logo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="250dp"
        android:layout_height="200dp"
        android:layout_below="@id/txtTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:src="@drawable/ic_aerix_logo"
        android:contentDescription="AERIX Logo"
        android:scaleType="fitCenter" />

    <!-- ABOUT AERIX CARD -->
    <LinearLayout
        android:id="@+id/cardAbout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_round"
        android:orientation="vertical"
        android:padding="18dp"
        android:layout_below="@+id/txtSubtitle"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:justificationMode="inter_character"
            android:padding="0dp"
            android:text="  AERIX (Air Emission Reduction Innovative eXhaust) is an anti-pollution exhaust system designed to monitor and reduce carbon monoxide (CO) emissions from motorcycles. The system integrates a CO gas sensor, an ESP32 microcontroller, and an Android application to enable real-time monitoring and data visualization.\n    The AERIX system applies an Electrostatic Precipitator (ESP) method to support emission reduction. Firebase Realtime Database is used as a backend service to handle data transmission, storage, visualization, and control commands between the hardware and the Android application."
            android:textColor="@android:color/white"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- DEVELOPMENT TEAM CARD -->
    <LinearLayout
        android:id="@+id/cardTeam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_round"
        android:orientation="vertical"
        android:padding="18dp"
        android:layout_below="@id/cardAbout"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Development Team"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="0dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:justificationMode="inter_character"
            android:text="• Ricky Safatulloh      - Sub Instrumentation Developer\n• Theo Christoper      - Sub Data Acquisition Developer\n• Muhammad Habib  - Sub Power Developer"
            android:textColor="#E0FFFFFF"
            android:textSize="10sp"

            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</RelativeLayout>
